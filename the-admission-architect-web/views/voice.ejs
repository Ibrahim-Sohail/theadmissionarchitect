<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IELTS Speaking AI | The Admission Architect</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons|Material+Icons+Outlined" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { background-color: #F9FAFB; min-height: 100vh; display: flex; flex-direction: column; margin: 0; }
        .speaking-layout { flex: 1; display: flex; flex-direction: column; max-width: 750px; margin: 30px auto; width: 100%; padding: 0 20px; gap: 20px; }
        .speaking-header { background: linear-gradient(135deg, #7B1FA2, #9C27B0); color: white; padding: 25px 30px; border-radius: 16px; display: flex; align-items: center; gap: 15px; }
        .speaking-header-icon { background: rgba(255,255,255,0.2); padding: 12px; border-radius: 50%; display: flex; }
        .topic-card { background: white; border-radius: 16px; padding: 25px 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); border-left: 5px solid #9C27B0; }
        .topic-card h3 { margin: 0 0 10px 0; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; color: #9C27B0; }
        .topic-text { font-size: 20px; color: #222; font-weight: 600; line-height: 1.5; margin: 0; }
        .mic-area { background: white; border-radius: 16px; padding: 40px 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); display: flex; flex-direction: column; align-items: center; gap: 20px; }
        #visualizer { display: flex; justify-content: center; align-items: flex-end; gap: 5px; height: 60px; }
        .bar { width: 8px; height: 8px; background: #CE93D8; border-radius: 4px; transition: height 0.1s ease; }
        .bar.active { background: #9C27B0; }
        .mic-btn { width: 90px; height: 90px; background: #9C27B0; border-radius: 50%; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; color: white; box-shadow: 0 4px 20px rgba(156,39,176,0.4); transition: all 0.3s; }
        .mic-btn:hover { background: #7B1FA2; transform: scale(1.05); }
        .mic-btn.listening { background: #F44336; animation: pulse 1.2s infinite; }
        .mic-btn i { font-size: 42px; }
        @keyframes pulse { 0%{box-shadow:0 0 0 0 rgba(244,67,54,0.4)} 70%{box-shadow:0 0 0 18px rgba(244,67,54,0)} 100%{box-shadow:0 0 0 0 rgba(244,67,54,0)} }
        #statusText { font-size: 15px; color: #666; font-weight: 500; text-align: center; }
        #transcriptBox { width: 100%; min-height: 80px; background: #F3E5F5; border-radius: 10px; padding: 15px; font-size: 15px; color: #333; box-sizing: border-box; display: none; line-height: 1.6; }
        #submitBtn { display: none; background: #9C27B0; color: white; border: none; padding: 14px 40px; border-radius: 30px; font-size: 16px; font-weight: bold; cursor: pointer; transition: background 0.3s; }
        #submitBtn:hover { background: #7B1FA2; }
        #resultCard { display: none; background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
        .band-score { font-size: 60px; font-weight: 800; color: #9C27B0; text-align: center; line-height: 1; }
        .band-label { text-align: center; color: #888; font-size: 14px; margin-bottom: 20px; }
        .feedback-text { background: #F9F9F9; border-radius: 10px; padding: 15px 20px; color: #444; font-size: 15px; line-height: 1.6; }
        .try-again-btn { display: block; margin: 20px auto 0; background: #333; color: white; border: none; padding: 12px 30px; border-radius: 30px; font-size: 15px; cursor: pointer; }
        #browserWarning { display: none; background: #FFF3E0; border: 1px solid #FF9800; border-radius: 10px; padding: 15px 20px; color: #E65100; font-size: 14px; text-align: center; }
        .spinner { display: none; width: 30px; height: 30px; border: 3px solid #E1BEE7; border-top-color: #9C27B0; border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto; }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>

    <%- include('partials/navbar') %>

    <div class="speaking-layout">
        <div class="speaking-header">
            <div class="speaking-header-icon"><i class="material-icons">mic</i></div>
            <div>
                <h2 style="margin:0;font-size:22px;">IELTS Speaking AI</h2>
                <p style="margin:0;font-size:13px;opacity:0.85;">Speak your answer — AI will transcribe and grade it</p>
            </div>
        </div>

        <div id="browserWarning">
            ⚠️ Speech recognition is not supported in this browser. Please use <strong>Google Chrome</strong> or <strong>Microsoft Edge</strong>.
        </div>

        <div class="topic-card">
            <h3>Your Topic</h3>
            <p class="topic-text" id="speakingTopicText">Loading topic...</p>
        </div>

        <div class="mic-area">
            <div id="visualizer">
                <div class="bar"></div><div class="bar"></div><div class="bar"></div>
                <div class="bar"></div><div class="bar"></div><div class="bar"></div>
                <div class="bar"></div><div class="bar"></div><div class="bar"></div>
            </div>

            <button class="mic-btn" id="micBtn" onclick="toggleMic()"><i class="material-icons" id="micIcon">mic</i></button>

            <p id="statusText">Tap the microphone to start speaking</p>
            <div id="transcriptBox"></div>
            <div class="spinner" id="spinner"></div>
            <button id="submitBtn" onclick="submitResponse()">Submit for Grading</button>
        </div>

        <div id="resultCard">
            <div class="band-score" id="bandScore">—</div>
            <div class="band-label">Band Score / 9.0</div>
            <div class="feedback-text" id="feedbackText"></div>
            <button class="try-again-btn" onclick="resetSession()">Try Again</button>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script>
        // ✅ Array of Random Speaking Topics
        const speakingTopics = [
            "Describe a memorable journey you have taken. Say: where you went, who you were with, what you did, and why it was memorable.",
            "Describe a book you recently read. Say: what the book was, who wrote it, what it was about, and why you liked it.",
            "Describe a person who has inspired you. Say: who they are, how you know them, what they have done, and explain why they inspire you.",
            "Describe a skill you would like to learn. Say: what the skill is, how you would learn it, and explain why you want to learn it."
        ];
        
        // Pick one at random and inject it into the page
        const currentTopic = speakingTopics[Math.floor(Math.random() * speakingTopics.length)];
        document.getElementById('speakingTopicText').innerText = currentTopic;

        let recognition = null;
        let isListening = false;
        let finalTranscript = '';
        let visualizerInterval = null;
        const bars = document.querySelectorAll('.bar');
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

        if (!SpeechRecognition) {
            document.getElementById('browserWarning').style.display = 'block';
            document.getElementById('micBtn').disabled = true;
            document.getElementById('micBtn').style.opacity = '0.4';
        } else {
            recognition = new SpeechRecognition();
            recognition.continuous = true;
            recognition.interimResults = true;
            recognition.lang = 'en-US';

            recognition.onresult = (event) => {
                let interim = '';
                finalTranscript = '';
                for (let i = 0; i < event.results.length; i++) {
                    if (event.results[i].isFinal) {
                        finalTranscript += event.results[i][0].transcript + ' ';
                    } else {
                        interim += event.results[i][0].transcript;
                    }
                }
                const box = document.getElementById('transcriptBox');
                box.style.display = 'block';
                box.innerText = (finalTranscript + interim).trim() || '...';
            };
            recognition.onerror = (e) => {
                stopListening();
                document.getElementById('statusText').innerText = 'Microphone error: ' + e.error + '. Please try again.';
            };
            recognition.onend = () => { if (isListening) stopListening(); };
        }

        function toggleMic() { isListening ? stopListening() : startListening(); }

        function startListening() {
            if (!recognition) return;
            finalTranscript = '';
            isListening = true;
            recognition.start();
            document.getElementById('micBtn').classList.add('listening');
            document.getElementById('micIcon').innerText = 'stop';
            document.getElementById('statusText').innerText = 'Listening... Tap stop when done.';
            document.getElementById('submitBtn').style.display = 'none';
            document.getElementById('transcriptBox').style.display = 'block';
            document.getElementById('transcriptBox').innerText = '...';
            visualizerInterval = setInterval(() => {
                bars.forEach(bar => {
                    bar.style.height = (Math.floor(Math.random() * 50) + 8) + 'px';
                    bar.classList.add('active');
                });
            }, 120);
        }

        function stopListening() {
            isListening = false;
            if (recognition) recognition.stop();
            clearInterval(visualizerInterval);
            bars.forEach(bar => { bar.style.height = '8px'; bar.classList.remove('active'); });
            document.getElementById('micBtn').classList.remove('listening');
            document.getElementById('micIcon').innerText = 'mic';
            if (finalTranscript.trim().length > 10) {
                document.getElementById('statusText').innerText = 'Done! Review your response below, then submit.';
                document.getElementById('submitBtn').style.display = 'block';
            } else {
                document.getElementById('statusText').innerText = 'Nothing captured. Please try again.';
                document.getElementById('transcriptBox').style.display = 'none';
            }
        }

        async function submitResponse() {
            const text = finalTranscript.trim();
            if (!text) return;
            document.getElementById('submitBtn').style.display = 'none';
            document.getElementById('micBtn').disabled = true;
            document.getElementById('statusText').innerText = 'Grading your response...';
            document.getElementById('spinner').style.display = 'block';
            try {
                const res = await fetch('/api/ielts/grade-speaking', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    // ✅ We send the randomized topic to the backend so the AI knows what it's grading!
                    body: JSON.stringify({ response_text: text, topic: currentTopic })
                });
                const data = await res.json();
                document.getElementById('spinner').style.display = 'none';
                if (data.error) {
                    document.getElementById('statusText').innerText = 'Error: ' + data.error;
                    document.getElementById('micBtn').disabled = false;
                    document.getElementById('submitBtn').style.display = 'block';
                    return;
                }
                document.getElementById('bandScore').innerText = data.band ?? data.score ?? '?';
                document.getElementById('feedbackText').innerText = data.feedback ?? data.message ?? 'No feedback available.';
                document.getElementById('resultCard').style.display = 'block';
                document.getElementById('statusText').innerText = 'Result saved to your profile!';
                document.getElementById('resultCard').scrollIntoView({ behavior: 'smooth' });
            } catch (err) {
                document.getElementById('spinner').style.display = 'none';
                document.getElementById('statusText').innerText = 'Connection error. Please try again.';
                document.getElementById('micBtn').disabled = false;
                document.getElementById('submitBtn').style.display = 'block';
            }
        }

        function resetSession() {
            finalTranscript = '';
            document.getElementById('resultCard').style.display = 'none';
            document.getElementById('transcriptBox').style.display = 'none';
            document.getElementById('transcriptBox').innerText = '';
            document.getElementById('submitBtn').style.display = 'none';
            document.getElementById('micBtn').disabled = false;
            document.getElementById('statusText').innerText = 'Tap the microphone to start speaking';
            bars.forEach(bar => { bar.style.height = '8px'; bar.classList.remove('active'); });
            
            // ✅ Randomize the topic again if they hit try again!
            const newTopic = speakingTopics[Math.floor(Math.random() * speakingTopics.length)];
            document.getElementById('speakingTopicText').innerText = newTopic;
        }
    </script>
</body>
</html>