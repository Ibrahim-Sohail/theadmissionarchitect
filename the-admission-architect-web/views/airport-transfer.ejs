<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Airport Transfer</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .transfer-header {
            background: url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80') center/cover no-radius;
            border-radius: 16px;
            padding: 60px 30px;
            text-align: center;
            color: white;
            position: relative;
            margin-bottom: 30px;
        }
        
        .transfer-header::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.6);
            border-radius: 16px;
        }
        
        .header-content { position: relative; z-index: 2; }
        
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        
        .form-group { display: flex; flex-direction: column; margin-bottom: 15px; }
        .form-group label { font-size: 13px; font-weight: bold; color: #555; margin-bottom: 8px; }
        .form-group input, .form-group select, .form-group textarea {
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 8px;
            font-family: inherit;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
            outline: none;
            border-color: #FF9800;
        }
        
        .full-width { grid-column: 1 / -1; }

        @media (max-width: 600px) { .form-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

    <div class="container">
        
        <a href="/home" style="display:inline-flex; align-items:center; gap:5px; text-decoration:none; color:#5A7B95; font-weight:bold; margin-bottom:20px;">
            <i class="material-icons" style="font-size: 18px;">arrow_back</i> Back to Dashboard
        </a>

        <div class="transfer-header">
            <div class="header-content">
                <i class="material-icons" style="font-size: 48px; color: #FF9800;">flight_land</i>
                <h1 style="margin: 10px 0;">Airport Transfer Booking</h1>
                <p style="font-size: 16px; opacity: 0.9;">Secure, reliable transportation from the airport to your new home.</p>
            </div>
        </div>

        <div class="card" style="padding: 30px;">
            <h3 style="margin-top: 0; color: #333; border-bottom: 2px solid #eee; padding-bottom: 10px;">Travel Itinerary & Logistics</h3>
            
            <form id="transferForm" onsubmit="submitTransfer(event)">
                <div class="form-grid">
                    
                    <div class="form-group">
                        <label>Arrival Airport in UK *</label>
                        <select required>
                            <option value="" disabled selected>Select Airport...</option>
                            <option value="LHR">London Heathrow (LHR)</option>
                            <option value="LGW">London Gatwick (LGW)</option>
                            <option value="MAN">Manchester Airport (MAN)</option>
                            <option value="BHX">Birmingham Airport (BHX)</option>
                            <option value="EDI">Edinburgh Airport (EDI)</option>
                            <option value="GLA">Glasgow Airport (GLA)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Flight Number *</label>
                        <input type="text" placeholder="e.g., BA 123, EK 007" required>
                    </div>

                    <div class="form-group">
                        <label>Date of Arrival *</label>
                        <input type="date" required>
                    </div>

                    <div class="form-group">
                        <label>Scheduled Arrival Time *</label>
                        <input type="time" required>
                    </div>

                    <div class="form-group">
                        <label>Number of Passengers *</label>
                        <select required>
                            <option value="1">1 Passenger (Just me)</option>
                            <option value="2">2 Passengers</option>
                            <option value="3">3 Passengers</option>
                            <option value="4+">4+ Passengers</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Estimated Luggage (Suitcases) *</label>
                        <input type="number" min="1" max="10" placeholder="Number of large bags" required>
                    </div>

                    <div class="form-group full-width">
                        <label>Destination Accommodation Address (Full) *</label>
                        <textarea rows="3" placeholder="Enter the exact address of your university accommodation or private rental including Postcode..." required></textarea>
                    </div>
                    
                    <div class="form-group full-width">
                        <label>Special Requirements (Optional)</label>
                        <input type="text" placeholder="e.g., Wheelchair access needed, traveling with pets, child seat required...">
                    </div>

                </div>

                <button type="submit" class="btn" style="background-color: #FF9800; font-size: 16px; padding: 15px; margin-top: 20px;">
                    Request Airport Transfer Quote ➜
                </button>
            </form>
        </div>

    </div>

    <div id="toast" style="visibility: hidden; min-width: 250px; background-color: #4CAF50; color: #fff; text-align: center; border-radius: 50px; padding: 16px; position: fixed; z-index: 2000; left: 50%; bottom: 30px; font-size: 15px; transform: translateX(-50%); box-shadow: 0 4px 10px rgba(0,0,0,0.2); transition: opacity 0.5s;">
        Transfer request submitted! We will email you the details.
    </div>

    <%- include('partials/navbar') %>

    <script>
        function submitTransfer(e) {
            e.preventDefault(); // Stop page reload
            
            const btn = e.target.querySelector('button');
            btn.innerHTML = 'Processing Request...';
            btn.style.opacity = '0.8';

            // Simulate server request
            setTimeout(() => {
                // Show Success Toast
                const toast = document.getElementById("toast");
                toast.style.visibility = "visible";
                toast.style.opacity = "1";
                
                // Reset form
                e.target.reset();
                btn.innerHTML = 'Request Airport Transfer Quote ➜';
                btn.style.opacity = '1';

                // Hide Toast after 4 seconds
                setTimeout(() => {
                    toast.style.opacity = "0";
                    setTimeout(() => { toast.style.visibility = "hidden"; }, 500);
                }, 4000);
            }, 1000);
        }
    </script>
</body>
</html>